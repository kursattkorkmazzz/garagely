{
  "expo": {
    "name": "Garagely",
    "slug": "garagely",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "garagely",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kursattkorkmazzz.garagely"
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "edgeToEdgeEnabled": true,
      "package": "com.kursattkorkmazzz.garagely"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-sqlite",
        {
          "enableFTS": false,
          "useSQLCipher": false,
          "ios": {
            // You can also override the shared configurations for iOS
            "customBuildFlags": [
              "-DSQLITE_ENABLE_DBSTAT_VTAB=1 -DSQLITE_ENABLE_SNAPSHOT=1"
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b727b5cb-97a9-4b82-b34e-56c204f49590"
      }
    }
  }
}
